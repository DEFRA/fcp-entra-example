{
  "name": "fcp-entra-example",
  "version": "0.1.0",
  "description": "Entra integration example",
  "homepage": "https://github.com/DEFRA/fcp-entra-example",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src src/index.js",
    "dev:debug": "NODE_ENV=development node --env-file-if-exists=.env --watch --watch-path=./src --inspect src/index.js",
    "docker:build": "docker compose --profile app build",
    "docker:dev": "docker compose --profile app up",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "local": "npm run services:up && npm run dev",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "start": "NODE_ENV=production node .",
    "test": "cross-env TZ=UTC vitest run --coverage",
    "test:unit": "cross-env TZ=UTC vitest run --coverage --project unit",
    "test:integration": "cross-env TZ=UTC vitest run --coverage --project integration",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:debug": "cross-env TZ=UTC vitest --inspect --no-file-parallelism"
  },
  "author": "Defra",
  "contributors": [
    "John Watson <john.watson1@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@hapi/bell": "13.1.0",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/cookie": "12.0.1",
    "@hapi/crumb": "9.0.1",
    "@hapi/hapi": "21.4.0",
    "@hapi/inert": "7.1.1",
    "@hapi/jwt": "3.2.4",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/wreck": "18.1.2",
    "@hapi/yar": "11.0.2",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "govuk-frontend": "5.11.1",
    "hapi-pino": "12.1.0",
    "joi": "18.2.1",
    "nunjucks": "3.2.4",
    "semver": "7.7.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.9",
    "chokidar": "3.6.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.4",
    "neostandard": "0.13.0",
    "testcontainers": "12.0.3",
    "vitest": "4.1.9"
  }
}
